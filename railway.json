{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm install --prefix Backend",
    "watchPatterns": [
      "Backend/**",
      "Frontend/**",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "npm start --prefix Backend",
    "healthcheckPath": "/api",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
